## Expo app environment (local development)
#
# Play Store / App Store (EAS production): set EXPO_PUBLIC_API_BASE_URL to a public **https://** API URL so the app
# disables cleartext traffic in the release build (see app.config.js).
#
# For a real phone over Wi‑Fi, prefer an HTTPS tunnel URL (ngrok/cloudflare) to avoid Android HTTP cleartext issues.
# Example:
# EXPO_PUBLIC_API_BASE_URL=https://xxxx.ngrok-free.app
#
# For Android emulator, you can leave this as-is; the app will auto-rewrite http://* to http://10.0.2.2:<port>
# when running on an Android emulator (so you can keep using your tunnel/LAN config without breaking emulator).
#
# If your backend runs locally on port 5000:
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.7:5000

# Optional: improves QR/LAN reliability for Expo dev server
REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.7

# Optional: request timeout in ms
EXPO_PUBLIC_API_TIMEOUT=60000

# Optional: maps key
EXPO_PUBLIC_GOOGLE_MAPS_TOKEN=
